# =====================================================================
# MyCarQR — Environment Variables (EXAMPLE / TEMPLATE)
#
# This file is checked into git on purpose so new developers know which
# env vars the app expects. It MUST contain placeholders only — never a
# real key. Copy this file to `.env` for local development, or paste the
# real values into your hosting provider's dashboard
# (Replit Secrets / Vercel / Render / Railway / Fly / etc.).
# =====================================================================

# ---- Database (REQUIRED) ----
# Postgres connection string. For Neon, use the POOLED connection string
# (it ends with `-pooler.<region>...`) and append `?sslmode=require`.
DATABASE_URL=your_database_connection_string_here

# ---- Clerk Auth (REQUIRED) ----
# From https://dashboard.clerk.com → API Keys.
# The publishable key is safe to expose to the browser; the secret key
# must NEVER be committed.
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
# Same publishable key, exposed to the browser via Vite. Keep them in sync.
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ---- API server runtime (REQUIRED) ----
# Port the Express server binds to. Vercel/Render/Railway will set this for you.
PORT=8080
# Set to "production" on real deployments. Controls logging format and CORS.
NODE_ENV=production

# ---- Frontend build (OPTIONAL — defaults to "/") ----
# The base URL the frontend is served from. "/" for root domains. Only set
# this if you deploy the frontend under a sub-path (e.g. "/app/").
BASE_PATH=/

# ---- Session secret (REQUIRED) ----
# Long random string (>= 32 chars) used to sign cookies / sessions.
# Generate with: openssl rand -hex 32
SESSION_SECRET=your_long_random_session_secret_here

# ---- Admin allowlist (recommended) ----
# Comma-separated list of email addresses that always have admin access,
# regardless of the users.is_admin DB flag. Useful as a lock-out safety net.
# A single hardcoded fallback also exists in artifacts/api-server/src/lib/adminEmails.ts
ADMIN_EMAILS=admin@yourdomain.com

# ---- CORS (REQUIRED when NODE_ENV=production) ----
# Comma-separated list of frontend origins allowed to call the API.
# In production the API will REFUSE TO START unless this is set, because
# allowing all origins with credentials is a security risk.
# In development this can be left unset (the API reflects the request origin).
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ---- Logging (optional) ----
LOG_LEVEL=info

# =====================================================================
# Optional integrations — uncomment + set the value as you add features.
# =====================================================================

# ---- Stripe (optional, only if you wire up Stripe payments) ----
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ---- Email / SMS providers (optional) ----
# RESEND_API_KEY=your_resend_api_key_here
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# ---- Object storage (REQUIRED for accident-report & lost-item photo uploads) ----
# Replit App Storage — provisioned automatically by the `setupObjectStorage()`
# helper in this Repl. On Replit deployments these three are populated for you;
# on other hosts you must point them at a Google Cloud Storage bucket and a
# service account that has access to it (the server uses ADC / GOOGLE_APPLICATION_CREDENTIALS).
#
# - DEFAULT_OBJECT_STORAGE_BUCKET_ID: GCS bucket name (no `gs://` prefix).
# - PRIVATE_OBJECT_DIR: bucket-prefixed path where new uploads are stored,
#   e.g. `/<bucket>/.private`. The server adds `/uploads/<uuid>` to it.
# - PUBLIC_OBJECT_SEARCH_PATHS: comma-separated bucket-prefixed paths checked
#   when serving `/api/public-objects/<name>` (used for static public assets).
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your_gcs_bucket_id_here
PRIVATE_OBJECT_DIR=/your_gcs_bucket_id_here/.private
PUBLIC_OBJECT_SEARCH_PATHS=/your_gcs_bucket_id_here/public
